# Copy this file to ".env" and paste your real key. .env is gitignored.
#
# Get a key at https://aistudio.google.com/apikey
# (create it inside a Google Cloud project linked to a billing account
#  so usage draws from your credits).
GEMINI_API_KEY=

# Optional overrides:
# Nano Banana 2 (Flash, fast/cheap) is the default. Switch to Pro for higher fidelity.
#   Flash: gemini-3.1-flash-image
#   Pro:   gemini-3-pro-image
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
